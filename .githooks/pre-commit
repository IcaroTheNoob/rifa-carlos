#!/bin/sh
# Pre-commit hook — Security scanner for hardcoded credentials
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '\.env' | grep -v '\.githooks/' | grep -v '\.gitignore')
[ -z "$FILES" ] && exit 0

echo ""
echo -e "${CYAN}[SECURITY] Scanning staged files...${NC}"

BLOCKED=0
for f in $FILES; do
    RESULTS=$(git show ":0:$f" 2>/dev/null | grep -inE '(postgresql://[a-z]|npg_[A-Za-z0-9]{8,}|password=[^"'"'"' ]|PASSWORD=[^"'"'"' ]|senha=[^"'"'"' ])' | head -5)
    if [ -n "$RESULTS" ]; then
        echo -e "  ${RED}[FAIL]${NC} $f"
        echo "$RESULTS" | while IFS=: read -r ln rest; do
            echo -e "     ${YELLOW}L$ln${NC} $(echo "$rest" | sed 's/^ *//' | head -c 70)"
        done
        BLOCKED=1
    fi
done

if [ "$BLOCKED" = "1" ]; then
    echo ""
    echo -e "${RED}[BLOCKED] Commit rejeitado!${NC}"
    echo "  Use: git commit --no-verify"
    echo ""
    exit 1
fi
echo -e "${GREEN}[PASS] OK${NC}"
exit 0

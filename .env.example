# ──────────────────────────────────────────────
# Configuração do ambiente — Rifa Carlos
# ──────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores:
#   cp .env.example .env.local
#
# NUNCA commite o .env.local com credenciais reais!

# ── Banco de Dados (Neon) ──
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://usuario:senha@host-unpooled/banco?sslmode=require"

# ── Neon Auth ──
NEON_AUTH_BASE_URL="https://<projeto>.neon-auth.<regiao>.aws.neon.tech/<banco>/auth"

# ── Admin ──
ADMIN_PASSWORD=""

# ── Postgres (individual) ──
PGHOST=""
PGHOST_UNPOOLED=""
PGPORT="5432"
PGDATABASE=""
PGUSER=""
PGPASSWORD=""
POSTGRES_DATABASE=""
POSTGRES_HOST=""
POSTGRES_PASSWORD=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL=""
POSTGRES_URL_NON_POOLING=""
POSTGRES_URL_NO_SSL=""
POSTGRES_USER=""

# ── Neon Project ──
NEON_PROJECT_ID=""

# ── Vercel (opcional — preenchido automaticamente em deploy) ──
VERCEL=""
VERCEL_ENV=""
VERCEL_URL=""
VERCEL_OIDC_TOKEN=""
